    "expo-location": "^55.1.8",
    "expo-sensors": "~14.0.0",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.0",
    "react-native-safe-area-context": "^5.3.0",
    "react-native-web": "^0.20.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "eas-cli": "^18.7.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
